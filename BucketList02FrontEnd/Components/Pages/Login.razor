@page "/login"
@inject HttpClient Http
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div style="max-width: 1000px; margin: 0 auto; padding: 40px 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center;
                margin-bottom: 30px; padding-bottom: 15px; border-bottom: 2px solid #e0e0e0;">
        <h3 style="font-size: 32px; font-weight: bold; margin: 0;">Login</h3>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <div class="mb-3 mt-3">
        <label for="userName">Gebruikersnaam:</label>
        <input type="text" class="form-control" id="userName"
               placeholder="Gebruikersnaam" @bind="userName" />
    </div>
    <div class="mb-3">
        <label for="pass">Wachtwoord:</label>
        <input type="password" class="form-control" id="pass"
               placeholder="Wachtwoord" @bind="pass" />
    </div>

    <button class="btn btn-primary" @onclick="LoginUser" disabled="@isLoading">
        @(isLoading ? "Bezig..." : "Login")
    </button>
</div>

@code {
    private string userName = "";
    private string pass = "";
    private string errorMessage = "";
    private bool isLoading = false;

    private async Task LoginUser()
    {
        errorMessage = "";
        isLoading = true;

        try
        {
            var url = $"/login?username={Uri.EscapeDataString(userName)}&password={Uri.EscapeDataString(pass)}";
            var response = await Http.GetAsync(url);

            if (response.IsSuccessStatusCode)
            {
                var user = await response.Content.ReadFromJsonAsync<UserDto>();
                // Store userId in sessionStorage so other pages can use it
                await JS.InvokeVoidAsync("sessionStorage.setItem", "userId", user!.IdUser.ToString());
                await JS.InvokeVoidAsync("sessionStorage.setItem", "userName", user.NameUser);
                Navigation.NavigateTo("/mijnlijst");
            }
            else if (response.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                errorMessage = "Foute gebruikersnaam of wachtwoord.";
            }
            else
            {
                errorMessage = "Onbekende fout bij login.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Kan geen verbinding maken met de server.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private class UserDto
    {
        public int IdUser { get; set; }
        public string NameUser { get; set; } = "";
    }
}